# Copy to .env and adjust for your setup.  .env is gitignored.
# The launcher (bin/ak-lxd-helper) and scripts source .env automatically.

# Hostname/alias of the machine running LXD. Used only by the dev SSH
# socket-forward (scripts/forward-socket.sh); the app itself never SSHes.
LXD_HOST=lxd-host

# Path to the LXD Unix socket the dashboard connects to.
#   On the LXD host:           /var/snap/lxd/common/lxd/unix.socket
#   On a dev laptop (forward): $HOME/.lxd.socket
# Leave unset to use auto-detection (see README "Configuration").
# LXD_SOCKET=

# Remote socket path on the LXD host (used by the SSH forward).
LXD_REMOTE_SOCKET=/var/snap/lxd/common/lxd/unix.socket

# Dashboard bind address/port.
AK_LXD_HOST=127.0.0.1
AK_LXD_PORT=8080

# Host resource monitor (CPU/GPU/mem/disk/net). "auto" runs locally when the
# dashboard is on the LXD host, else over SSH to LXD_HOST. Other: local|ssh|off.
HOST_STATS=auto

# Lab VM LAN SSH (macvlan). Credentials cloud-init sets and the dashboard shows.
LAB_VM_USER=lab
LAB_VM_PASSWORD=change-me
LAB_LAN_PARENT=enP7s7          # host LAN NIC the macvlan attaches to
