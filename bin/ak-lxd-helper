#!/usr/bin/env bash
# Launch the ak-lxd-helper dashboard inside its conda environment.
# Creates the env from environment.yml on first run.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# Load local config (host names, socket path, port) if present.
if [[ -f "$ROOT/.env" ]]; then
  set -a; # shellcheck disable=SC1091
  . "$ROOT/.env"; set +a
fi

ENV_NAME="${AK_LXD_CONDA_ENV:-ak-lxd-helper}"

# Load conda's shell functions.
if ! command -v conda >/dev/null 2>&1; then
  echo "error: conda not found on PATH" >&2
  exit 1
fi
# shellcheck disable=SC1091
source "$(conda info --base)/etc/profile.d/conda.sh"

if ! conda activate "$ENV_NAME" 2>/dev/null; then
  echo "Creating conda env '$ENV_NAME' from environment.yml…"
  conda env create -f environment.yml
  conda activate "$ENV_NAME"
fi

export PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
exec python -m aklxd.server "$@"
