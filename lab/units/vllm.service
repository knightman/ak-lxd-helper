# lab-004-vllm — vLLM serving Qwen/Qwen3-8B with tool calling.
# Deploy inside the container at /etc/systemd/system/vllm.service:
#   lxc file push lab/units/vllm.service lab-004-vllm/etc/systemd/system/vllm.service --mode=0644
#   lxc exec lab-004-vllm -- systemctl daemon-reload
#   lxc exec lab-004-vllm -- systemctl enable --now vllm.service
# The --enable-auto-tool-choice / --tool-call-parser hermes flags are REQUIRED for
# OpenAI tool/function calling (e.g. pi's web_search); see lab/specs/004-vllm-qwen.md.
[Unit]
Description=vLLM serving Qwen/Qwen3-8B (lab-004) with tool calling
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=lab
Group=lab
WorkingDirectory=/home/lab
ExecStart=/home/lab/.venv/bin/vllm serve Qwen/Qwen3-8B --host 0.0.0.0 --port 8000 --gpu-memory-utilization 0.20 --max-model-len 8192 --enable-auto-tool-choice --tool-call-parser hermes
Restart=on-failure
RestartSec=5
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
